{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",

  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "sgbvehiclefinance.com"
        }
      ],
      "destination": "https://www.sgbvehiclefinance.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.sgbvehiclefinance.com"
        }
      ],
      "destination": "https://www.sgbvehiclefinance.com/$1",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}